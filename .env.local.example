# API-Football ingest and Supabase
# Apply supabase/migrations/20260331_create_api_football_ingest_tables.sql before the first live ingest run.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
API_FOOTBALL_KEY=your-api-football-key

# Postgres / Schema Validation
# The schema runtime scripts accept any one of these keys.
# For Supabase, prefer the session/transaction pooler URL in IPv4-only environments.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/worldcapiq
# SUPABASE_DB_URL=postgres://postgres:postgres@127.0.0.1:5432/worldcapiq
# POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/worldcapiq

# Layer 1 Team Data (optional overrides for ZON-8 live sync)
LAYER1_COMPETITION=World Cup 2026
LAYER1_SEASON=2026
LAYER1_SOURCE_MODE=live
LAYER1_FALLBACK_TO_CSV=false
FBREF_SHOOTING_URL=https://fbref.com/en/comps/1/2026/shooting/2026-World-Cup-Stats
FBREF_PASSING_URL=https://fbref.com/en/comps/1/2026/passing/2026-World-Cup-Stats
FBREF_POSSESSION_URL=https://fbref.com/en/comps/1/2026/possession/2026-World-Cup-Stats
ELO_RATINGS_URL=https://eloratings.net/
FBREF_TEAM_STATS_CSV_FILE=/absolute/path/fbref-team-stats.csv
ELO_RATINGS_CSV_FILE=/absolute/path/elo-ratings.csv

# Example competition that currently exposes Squad Stats tables on FBref:
# LAYER1_COMPETITION=UEFA Euro 2024
# LAYER1_SEASON=2024
# FBREF_SHOOTING_URL=https://fbref.com/en/comps/676/shooting/UEFA-Euro-Stats
# FBREF_PASSING_URL=https://fbref.com/en/comps/676/passing/UEFA-Euro-Stats
# FBREF_POSSESSION_URL=https://fbref.com/en/comps/676/possession/UEFA-Euro-Stats

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_TOURNAMENT_PRICE_ID=price_xxx

# v4 Paywall: Consumer pass Stripe price IDs
STRIPE_MATCH_PASS_PRICE_ID=price_xxx
STRIPE_TEAM_PASS_PRICE_ID=price_xxx
STRIPE_TOURNAMENT_PASS_PRICE_ID=price_xxx
STRIPE_SCOUT_PASS_PRICE_ID=price_xxx

# v4 Paywall: B2B API Stripe price IDs (updated tiers)
STRIPE_API_DEVELOPER_PRICE_ID=price_xxx
STRIPE_API_PROFESSIONAL_PRICE_ID=price_xxx

# B2B API: Stripe price IDs for API subscription tiers (legacy)
STRIPE_API_BASIC_PRICE_ID=price_xxx
STRIPE_API_ADVANCED_PRICE_ID=price_xxx
STRIPE_API_EVENT_PRICE_ID=price_xxx

# B2B API: Upstash Redis (rate limiting across serverless instances)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# B2B API: HMAC pepper for API key hashing (generate: openssl rand -base64 32)
API_KEY_PEPPER=your-random-pepper-secret

# Google Tag Manager / GA4
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google AdSense
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:push@worldcapiq.com
