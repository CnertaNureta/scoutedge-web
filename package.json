{
  "name": "scoutedge-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:schema": "vitest run src/lib/__tests__/core-football-schema.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "schema:apply": "bash scripts/apply-core-football-schema.sh",
    "schema:doctor": "bash scripts/doctor-core-football-schema.sh",
    "schema:smoke": "bash scripts/smoke-core-football-schema.sh",
    "schema:validate": "bash scripts/validate-core-football-schema.sh",
    "schema:verify": "bash scripts/verify-core-football-schema.sh",
    "typecheck": "tsc --noEmit",
    "generate:player-intel": "node --experimental-strip-types scripts/generate-player-intel.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@serwist/next": "^9.5.7",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tailwindcss/typography": "^0.5.19",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.5",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serwist": "^9.5.7",
    "stripe": "^21.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2",
    "ws": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0"
    ]
  }
}
