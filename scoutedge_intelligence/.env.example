# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Models (defaults defined in code; override only when experimenting)
ANTHROPIC_MODEL_FEATURE_GEN=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_TRANSLATOR=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_ANALYST=claude-sonnet-4-6
ANTHROPIC_MODEL_SYNTHESIZER=claude-sonnet-4-6

# Database (Supabase)
DATABASE_URL=postgresql://user:pass@localhost:5432/scoutedge
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Redis
REDIS_URL=redis://localhost:6379

# Sportsbook
ODDS_API_KEY=
ODDS_API_REGIONS=us,uk,eu
ODDS_API_BOOKMAKERS=pinnacle,draftkings,bet365,williamhill_us

# api-football
API_FOOTBALL_KEY=

# Polymarket (Gamma API needs no auth for read; CLOB does for trade — we only read)
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com

# Polymarket weight cap (decision: cap at 0.15 if WC market 24h volume < $10K)
POLYMARKET_WEIGHT_HARD_CAP=0.15
POLYMARKET_VOLUME_THRESHOLD_USD=10000

# Feature flags
ANALYST_ENABLED=true
ANALYST_HIGH_DIVERGENCE_ONLY=false

# Service
PORT=8080
LOG_LEVEL=INFO
# FastAPI settings expect CORS_ORIGINS as a JSON array string.
CORS_ORIGINS='["http://localhost:3000","https://scoutedge.app"]'
